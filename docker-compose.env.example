# Copy to .env before running `docker compose up -d --build`

FRONTEND_PORT=20320
VITE_BASE_PATH=/

POSTGRES_DB=privacy_policy_archive
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Use production only when you have HTTPS in front of frontend/backend.
APP_ENV=development
APP_NAME=privacy-policy-archive-api
CORS_ORIGINS=http://localhost,http://127.0.0.1

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@123
ADMIN_TOKEN=change-me
JWT_SECRET=change-this-secret
JWT_EXPIRE_SECONDS=43200

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
APK_MAX_UPLOAD_MB=300

# true: run `python scripts/seed_sample_data.py` automatically after migrations
SEED_SAMPLE_DATA=false

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
