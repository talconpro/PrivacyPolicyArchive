{
  "name": "privacy-policy-archive",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for archiving and analyzing privacy policies",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @privacy-policy-archive/web dev",
    "build": "pnpm --filter @privacy-policy-archive/web build",
    "start": "pnpm --filter @privacy-policy-archive/web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "update": "tsx scripts/runUpdate.ts",
    "update:policies": "tsx scripts/runUpdate.ts",
    "submission:server": "tsx scripts/submissionServer.ts",
    "submissions:process": "tsx scripts/processSubmissions.ts",
    "review:queue": "tsx scripts/reviewQueue.ts list",
    "preflight": "tsx scripts/preflight.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.17.31",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
