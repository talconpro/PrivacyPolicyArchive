generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
  UNKNOWN
}

enum FetchStatus {
  PENDING
  SUCCESS
  FAILED
  NEEDS_REVIEW
}

enum ReviewStatus {
  PENDING
  APPROVED
  CORRECTED
  FALSE_POSITIVE
}

enum DocumentType {
  PRIVACY_POLICY
  TERMS_OF_SERVICE
  UNKNOWN
}

model App {
  id              String                @id @default(cuid())
  slug            String?               @unique
  name            String
  bundleId        String?               @unique
  category        String?
  developer       String?
  iconUrl         String?
  websiteUrl      String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  policies        PolicyVersion[]
  changes         PolicyChange[]
  changeSummaries PolicyChangeSummary[]

  @@index([name])
  @@index([category])
}

model PolicyVersion {
  id              String                @id @default(cuid())
  appId            String
  documentType     DocumentType          @default(PRIVACY_POLICY)
  sourceUrl        String
  checksum         String?
  contentHash      String
  versionNo        Int                   @default(1)
  isCurrent        Boolean               @default(true)
  fetchedAt        DateTime              @default(now())
  rawText          String
  normalizedText   String
  contentType      String?
  fetchStatus      FetchStatus           @default(PENDING)
  app              App                   @relation(fields: [appId], references: [id], onDelete: Cascade)
  analyses         Analysis[]
  changesFrom      PolicyChange[]        @relation("FromVersion")
  changesTo        PolicyChange[]        @relation("ToVersion")
  summariesFrom    PolicyChangeSummary[] @relation("SummaryFrom")
  summariesTo      PolicyChangeSummary[] @relation("SummaryTo")

  @@unique([appId, contentHash])
  @@unique([appId, documentType, versionNo])
  @@index([appId, isCurrent])
  @@index([appId, fetchedAt])
  @@index([fetchStatus])
}

model Analysis {
  id               String       @id @default(cuid())
  policyVersionId  String
  oneLineSummary   String?
  summary          String?
  riskScore        Float?
  riskLevel        RiskLevel    @default(UNKNOWN)
  riskReasons      String?
  confidence       Float?
  needsHumanReview Boolean      @default(false)
  reviewStatus     ReviewStatus @default(PENDING)
  reviewReason     String?
  reviewPriority   Int?
  normalizedPayload String?
  modelName        String?
  createdAt        DateTime     @default(now())
  policyVersion    PolicyVersion @relation(fields: [policyVersionId], references: [id], onDelete: Cascade)

  @@index([policyVersionId, riskLevel])
  @@index([riskLevel, needsHumanReview])
  @@index([reviewStatus, reviewPriority])
}

model PolicyChange {
  id            String        @id @default(cuid())
  appId         String
  fromVersionId String
  toVersionId   String
  title         String
  description   String
  riskLevel     RiskLevel     @default(MEDIUM)
  createdAt     DateTime      @default(now())
  app           App           @relation(fields: [appId], references: [id], onDelete: Cascade)
  fromVersion   PolicyVersion @relation("FromVersion", fields: [fromVersionId], references: [id], onDelete: Cascade)
  toVersion     PolicyVersion @relation("ToVersion", fields: [toVersionId], references: [id], onDelete: Cascade)

  @@unique([fromVersionId, toVersionId, title])
  @@index([appId, createdAt])
  @@index([riskLevel])
}

model PolicyChangeSummary {
  id              String        @id @default(cuid())
  appId           String
  fromVersionId   String
  toVersionId     String
  changeSummary   String
  changeHighlights String
  createdAt       DateTime      @default(now())
  app             App           @relation(fields: [appId], references: [id], onDelete: Cascade)
  fromVersion     PolicyVersion @relation("SummaryFrom", fields: [fromVersionId], references: [id], onDelete: Cascade)
  toVersion       PolicyVersion @relation("SummaryTo", fields: [toVersionId], references: [id], onDelete: Cascade)

  @@unique([fromVersionId, toVersionId])
  @@index([appId, createdAt])
}
