generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model App {
  id                 String          @id @default(cuid())
  slug               String          @unique
  name               String          @unique
  category           String
  developer          String?
  iconUrl            String?
  privacyPolicyUrl   String?
  termsOfServiceUrl  String?
  rawText            String?
  analysis           Json?
  analysisSource     Json?
  riskLevel          String?
  oneLiner           String?
  plainSummary       String?
  status             String          @default("draft") // draft review_ready published archived
  reviewNotes        String?
  featured           Boolean         @default(false)
  warningPinned      Boolean         @default(false)
  isPublished        Boolean         @default(false)
  sourceType         String          @default("manual")
  sourceSubmissionId String?
  analyzedAt         DateTime?
  updatedAt          DateTime        @updatedAt
  createdAt          DateTime        @default(now())
  contentHash        String?
  lastFetchAt        DateTime?
  lastError          String?
  versions           PolicyVersion[]
  logs               AuditLog[]
}

model PolicyVersion {
  id              String   @id @default(cuid())
  appId           String
  app             App      @relation(fields: [appId], references: [id])
  versionLabel    String?
  rawText         String
  contentHash     String
  analysis        Json?
  diffSummary     Json?
  sourceUrl       String?
  createdAt       DateTime @default(now())
}

model UserSubmission {
  id                String   @id @default(cuid())
  appName           String
  privacyUrl        String
  termsUrl          String?
  remark            String?
  submitterEmail    String?
  ipHash            String
  status            String   @default("pending") // pending processing review_ready needs_revision approved rejected failed superseded
  fetchStatus       String   @default("idle")
  analysisStatus    String   @default("idle")
  adminNote         String?
  processingError   String?
  extractedText     String?
  extractedHash     String?
  suggestedRisk     String?
  analysisDraft     Json?
  linkedAppId       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  approvedAt        DateTime?
}

model CrawlJob {
  id           String   @id @default(cuid())
  type         String
  status       String   @default("queued") // queued running success failed
  targetType   String?
  targetId     String?
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  summary      String?
  log          String?
  meta         Json?
}

model AuditLog {
  id          String   @id @default(cuid())
  appId        String?
  app          App?     @relation(fields: [appId], references: [id])
  entityType   String
  entityId     String
  action       String
  actor        String
  before       Json?
  after        Json?
  createdAt    DateTime @default(now())
}
